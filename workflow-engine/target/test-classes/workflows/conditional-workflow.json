{
  "id": "conditional-workflow",
  "version": "1.0.0",
  "type": "REGULAR",
  "startStep": "evaluate-decision",
  "steps": [
    {
      "id": "evaluate-decision",
      "resource": "decisionExecutor",
      "transitions": [
        {
          "condition": "#context.variables['decision'] == true",
          "nextStep": "add-value"
        },
        {
          "condition": "#context.variables['decision'] == false",
          "nextStep": "end-step"
        }
      ]
    },
    {
      "id": "add-value",
      "resource": "addNumberExecutor"
    },
    {
      "id": "end-step",
      "resource": "decisionExecutor"
    }
  ]
}
